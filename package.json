{
    "name": "discrete-probabilities",
    "version": "1.0.0",
    "description": "Utilities for discrete probabilistic programming",
    "keywords": [
        "probability",
        "probabilistic",
        "HANSEI"
    ],
    "license": "MIT",
    "author": "Joseph Junker",
